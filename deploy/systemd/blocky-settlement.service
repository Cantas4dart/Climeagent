[Unit]
Description=Blocky settlement monitor
After=network-online.target blocky-executor.service
Wants=network-online.target

[Service]
Type=simple
User=blocky
Group=blocky
WorkingDirectory=/opt/blocky-polymarket
EnvironmentFile=/opt/blocky-polymarket/.env
ExecStart=/opt/blocky-polymarket/.venv/bin/python -m pyapp.settlement
Restart=always
RestartSec=10
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/blocky-polymarket/data

[Install]
WantedBy=multi-user.target
