[Unit]
Description=Climeagent Telegram bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=climeagent
Group=climeagent
WorkingDirectory=/opt/climeagent
EnvironmentFile=/opt/climeagent/.env
ExecStart=/opt/climeagent/.venv/bin/python -m pyapp.bot
Restart=always
RestartSec=10
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/climeagent/data

[Install]
WantedBy=multi-user.target
